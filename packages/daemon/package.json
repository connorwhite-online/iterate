{
  "name": "iterate-ui-daemon",
  "version": "0.1.6",
  "description": "iterate daemon — control server, worktree manager, proxy",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/connorwhite-online/iterate",
    "directory": "packages/daemon"
  },
  "homepage": "https://iterate-ui.com",
  "keywords": ["iterate", "ui", "daemon", "worktree", "proxy", "fastify"],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "prepublishOnly": "pnpm build",
    "build": "tsup src/index.ts --format esm --dts",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "clean": "rm -rf dist",
    "test": "vitest run"
  },
  "dependencies": {
    "iterate-ui-core": "workspace:*",
    "iterate-ui-overlay": "workspace:*",
    "fastify": "^5.2.0",
    "@fastify/websocket": "^11.0.0",
    "@fastify/static": "^8.0.0",
    "@fastify/reply-from": "^12.0.0",
    "simple-git": "^3.27.0",
    "execa": "^9.5.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0"
  }
}
