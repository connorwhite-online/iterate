{
  "name": "iterate-ui-mcp",
  "version": "0.1.5",
  "description": "MCP server for iterate — AI agent integration",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/connorwhite-online/iterate",
    "directory": "packages/mcp"
  },
  "homepage": "https://iterate-ui.com",
  "keywords": ["iterate", "ui", "mcp", "model-context-protocol", "ai", "agent"],
  "engines": {
    "node": ">=18.0.0"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "bin": {
    "iterate-ui-mcp": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "prepublishOnly": "pnpm build",
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "test": "vitest run"
  },
  "dependencies": {
    "iterate-ui-core": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "ws": "^8.18.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0"
  }
}
