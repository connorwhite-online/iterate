{
  "name": "iterate-ui-core",
  "version": "0.1.3",
  "description": "Shared types and protocol for iterate",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/connorwhite-online/iterate",
    "directory": "packages/core"
  },
  "homepage": "https://iterate-ui.com",
  "keywords": [
    "iterate",
    "ui",
    "types",
    "protocol"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "import": "./dist/node.js",
      "require": "./dist/node.cjs"
    }
  },
  "scripts": {
    "prepublishOnly": "pnpm build",
    "build": "tsup src/index.ts src/node.ts --format esm,cjs --dts",
    "dev": "tsup src/index.ts src/node.ts --format esm,cjs --dts --watch",
    "clean": "rm -rf dist",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "^22.19.11",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  }
}
