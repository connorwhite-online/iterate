{
  "name": "iterate-ui-core",
  "version": "0.1.0",
  "description": "Shared types and protocol for iterate",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/connorwhite-online/iterate",
    "directory": "packages/core"
  },
  "homepage": "https://iterate-ui.com",
  "keywords": ["iterate", "ui", "types", "protocol"],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.7.0"
  }
}
